# Copy this file to .env and fill in your values

# Deployer wallet private key (TESTNET ONLY — never use a mainnet key here)
PRIVATE_KEY=

# Rootstock RPC endpoints (defaults work fine, override if needed)
RSK_TESTNET_RPC=https://public-node.testnet.rsk.co
RSK_MAINNET_RPC=https://public-node.rsk.co

# Filled after running: npx hardhat run scripts/deploy.ts --network rskTestnet
NEXT_PUBLIC_CONTRACT_ADDRESS=
NEXT_PUBLIC_CHAIN_ID=31
